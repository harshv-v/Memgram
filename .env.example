# Copy to .env and fill in. docker-compose reads this file automatically.

# --- Database (one Postgres does vectors + relational; AGE graph opt-in) ---
DATABASE_URL=postgresql://memgram:memgram@localhost:5432/memgram
MEMGRAM_EMBED_DIMS=1536          # 1536 for OpenAI text-embedding-3-small; set BEFORE first migrate for local models
# Host ports default to 5432 (db) and 6379 (queue). If those are already taken
# on your machine, remap the host side here (container ports never change) and
# update DATABASE_URL / REDIS_URL below to match:
# MEMGRAM_DB_PORT=5433
# MEMGRAM_QUEUE_PORT=6380

# --- Queue (Redis OR Valkey — we code to the protocol) ---
REDIS_URL=redis://localhost:6379/0

# --- API auth ---
MEMGRAM_API_KEY=mgram_dev_key      # bearer token your SDK uses; change for anything real

# --- LLM brain (default OpenAI; any OpenAI-compatible endpoint works) ---
OPENAI_API_KEY=                 # required for extraction/reflection (the LLM agents)
# MEMGRAM_LLM_BASE_URL=http://localhost:11434/v1   # e.g. Ollama / vLLM / Groq

# --- Embeddings: openai (1536d, best quality, ~300ms/query network hop)
#                 local  (384d ONNX in-process, ~10ms/query, no network, private)
#                 fake   (tests). Set DIMS to match BEFORE first migrate; switching
#                 backends needs a fresh DB (you can't mix dimensions).
# MEMGRAM_EMBEDDER=local
# MEMGRAM_EMBED_DIMS=384                 # 384 for local bge-small; 1536 for OpenAI
# MEMGRAM_EMBED_MODEL=text-embedding-3-small        # (openai backend)
# MEMGRAM_LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5  # (local backend)

# --- Model tiers (extractor/summarizer = fast; reflection/proposer = quality) ---
# MEMGRAM_FAST_MODEL=gpt-4o-mini
# MEMGRAM_QUALITY_MODEL=gpt-4o     # design spec; repoint if gpt-4o is unavailable

# --- Behaviour preset + summarizer trigger (worker reads MEMGRAM_PRESET) ---
# MEMGRAM_PRESET=chatbot           # minimal | chatbot | coding | enterprise | privacy | custom
# MEMGRAM_CONTEXT_LIMIT=26000
# MEMGRAM_SUMMARIZE_THRESHOLD=0.6  # summarize when a request exceeds this fraction of the limit

# --- Zero-infra dev switches (no external calls at all) ---
# MEMGRAM_FAKE_LLM=1             # canned agent + embedding responses
# MEMGRAM_FAKE_REDIS=1          # in-process fakeredis

# --- Optional ---
# MEMGRAM_WEBHOOK_ON_PROPOSAL=https://your.app/webhooks/proposal
# MEMGRAM_LOG_LEVEL=INFO

# --- Background brain (the worker's LLM) -------------------------------------
# openai (default) | deepseek | gemini | groq | anthropic | watsonx
# Cheap picks: deepseek (~$0.14/M in) or gemini flash-lite (~$0.10/M in).
# MEMGRAM_FAST_MODEL / MEMGRAM_QUALITY_MODEL override the preset's model ids.
#MEMGRAM_BRAIN=deepseek
#DEEPSEEK_API_KEY=
#GEMINI_API_KEY=
#GROQ_API_KEY=
#ANTHROPIC_API_KEY=
#WATSONX_APIKEY=
#WATSONX_URL=https://us-south.ml.cloud.ibm.com
#WATSONX_PROJECT_ID=
# Per-model prompt tweaks without code edits (additive):
#MEMGRAM_PROMPT_SUFFIX_EXTRACTOR_SYSTEM=
